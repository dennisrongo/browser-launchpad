{
  "name": "browser-launchpad",
  "version": "1.0.0",
  "description": "A modern Chrome Extension that replaces the new tab page with a customizable, widget-based dashboard",
  "author": "Dennis Rongo",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc && vite build",
    "preview": "vite preview",
