{
  "manifest_version": 3,
  "name": "Browser Launchpad",
  "version": "1.0.0",
  "description": "A customizable, widget-based dashboard for your new tab page",
  "author": "Dennis Rongo",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "Browser Launchpad"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "oauth2": {
    "client_id": "59450688067-pumeg8a8aknnq4ek5qp098190m3qh6fd.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.appdata"
    ]
  },
  "permissions": [
    "storage",
    "identity"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://* http://*; img-src 'self' https://* http://* data:"
  }
}
